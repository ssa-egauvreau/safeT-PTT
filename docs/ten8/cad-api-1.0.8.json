{"openapi":"3.0.3","info":{"title":"10-8 CAD Incident API","version":"1.0.8","description":"10-8 Systems API for incidents.\n\nThis spec covers:\n- health check\n- create incident\n- list open incidents or filter by timestamp range\n- get incident by numeric ID or incident lookup\n- create/update comments\n- add/remove tags\n- add/remove persons\n- add/remove vehicles\n"},"servers":[{"url":"https://ps569km5w9.execute-api.us-gov-west-1.amazonaws.com/prod"},{"url":"https://connect.10-8systems.com"}],"tags":[{"name":"Health"},{"name":"Incidents"},{"name":"Comments"},{"name":"Tags"},{"name":"Persons"},{"name":"Vehicles"}],"security":[{"ApiKeyAuth":[]}],"components":{"securitySchemes":{"ApiKeyAuth":{"type":"apiKey","in":"header","name":"X-API-Key"},"ApiSecretAuth":{"type":"apiKey","in":"header","name":"X-API-Secret"}},"parameters":{"LookupParam":{"name":"lookup","in":"path","required":true,"description":"Numeric global incident ID or primary incident number (for example `25-0129`).","schema":{"type":"string","examples":{"numericId":{"value":"12345"},"incidentNumber":{"value":"25-0129"},"alternateIncident":{"value":"FD-1234"}}}},"CommentIdParam":{"name":"commentId","in":"path","required":true,"schema":{"type":"integer"}}},"schemas":{"ErrorResponse":{"type":"object","properties":{"error":{"type":"string"},"message":{"type":"string"}}},"HealthResponse":{"type":"object","properties":{"ok":{"type":"boolean"},"service":{"type":"string"}}},"Comment":{"type":"object","properties":{"id":{"type":"integer"},"callid":{"type":"integer"},"userID":{"type":"integer"},"time":{"type":"string"},"timestamp":{"type":"integer"},"officer":{"type":"string"},"comment":{"type":"string"},"type":{"type":"string"},"isEdited":{"type":"integer"}}},"Tag":{"type":"object","properties":{"id":{"type":"integer"},"tagID":{"type":"integer"},"tag":{"type":"string"}}},"Person":{"type":"object","properties":{"id":{"type":"integer"},"personID":{"type":"integer"},"relation":{"type":"string"},"notes":{"type":"stri