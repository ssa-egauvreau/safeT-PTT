"Disposition":{"type":"object","properties":{"disposition":{"type":"string"},"notes":{"type":"string"},"name":{"type":"string","description":"Display name of the user who set the disposition."},"timestamp":{"type":"integer","format":"int64","description":"Unix timestamp in seconds."}}},"CallUnit":{"type":"object","properties":{"id":{"type":"integer"},"unitID":{"type":"integer"},"unit":{"type":"string"},"status":{"type":"string"},"assignment":{"type":"string"},"dispatched":{"type":"string"},"enroute":{"type":"string"},"onscene":{"type":"string"},"transporting":{"type":"string"},"destination":{"type":"string"},"complete":{"type":"string"},"time_dispatched":{"type":"integer","nullable":true},"time_enroute":{"type":"integer","nullable":true},"time_onscene":{"type":"integer","nullable":true},"time_transporting":{"type":"integer","nullable":true},"time_destination":{"type":"integer","nullable":true},"time_complete":{"type":"integer","nullable":true},"users":{"type":"array","description":"Users assigned to this unit on this call.","items":{"$ref":"#/components/schemas/UserSummary"}}}},"Incident":{"type":"object","description":"Call/incident record with related collections.","properties":{"id":{"type":"integer"},"status":{"type":"string"},"idPrefix":{"type":"string"},"agencyID":{"type":"integer"},"code":{"type":"string"},"isClosed":{"type":"integer"},"type":{"type":"string"},"priority":{"type":"string","nullable":true},"channel":{"type":"string"},"source":{"type":"integer","nullable":true},"jurisdiction":{"type":"integer","nullable":true},"location":{"type":"string"},"latlng":{"type":"string"},"lat":{"type":"number"},"lng":{"type":"number"},"address":{"type":"string"},"city":{"type":"string"},"county":{"type":"string"},"state":{"type":"string"},"zip":{"type":"string"},"xstreet":{"type":"string"},"map":{"type":"string"},"locnotes":{"type":"string"},"rpname":{"type":"string"},"rplocation":{"type":"string"},"rpphone":{"type":"string"},"rpcontact":{"type":"string"},"dispatcher"