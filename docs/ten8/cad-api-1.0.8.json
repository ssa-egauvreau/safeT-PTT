y":{"type":"string"},"units":{"oneOf":[{"type":"string","description":"Comma-separated unit list."},{"type":"array","items":{"type":"string"}}]}},"example":{"type":"Traffic Collision","priority":"1","location":"123 Main St","latlng":"33.717, -117.831","streetAddress":"123 Main St","city":"Anaheim","county":"Orange","state":"CA","zip":"92805","xstreet":"1st St","apt":"2B","locnotes":"Rear parking lot","rpname":"Jane Doe","rpphone":"555-111-2222","rpcontact":true,"rplocation":"On scene","destination":"St. Joseph Hospital","dispatcher":"API User","isScheduled":0,"acknowledged":true,"summary":"Caller reports two vehicles blocking roadway.","units":["A12","E4"]}},"AddCommentRequest":{"type":"object","required":["comment"],"properties":{"officer":{"type":"string"},"comment":{"type":"string"},"type":{"type":"string","default":"comment"}},"example":{"officer":"Dispatcher 1","comment":"Additional caller reports smoke.","type":"update"}},"UpdateCommentRequest":{"type":"object","required":["comment"],"properties":{"comment":{"type":"string"}},"example":{"comment":"Corrected initial note."}},"AddTagRequest":{"type":"object","properties":{"tagId":{"type":"integer"},"tag":{"type":"string"}},"example":{"tag":"Hazmat"}},"RemoveTagRequest":{"type":"object","required":["tagId"],"properties":{"tagId":{"type":"integer"}},"example":{"tagId":12}},"AddPersonRequest":{"type":"object","properties":{"personId":{"type":"integer","description":"Optional. Used when person ID is already known, otherwise add person object."},"relation":{"type":"string"},"notes":{"type":"string"},"person":{"type":"object","properties":{"firstName":{"type":"string"},"middleName":{"type":"string"},"lastName":{"type":"string"},"alias":{"type":"string"},"dob":{"type":"string"},"address":{"type":"string"},"city":{"type":"string"},"county":{"type":"string"},"state":{"type":"string"},"zip":{"type":"string"},"email":{"type":"string"},"phone":{"type":"string"},"sex":{"type":"string"},"race":{"type":"string"},"height":{"type":"string"},"weight":{"type":"integer"},"eyes":{"type":"string"},"hair":{"type":"string"},"features":{"type":"string"},"stateID":{"type":"string"},"stateIDNumber":{"type":"string"},"profileImage":{"type":"string"},"isJuvenile":{"type":"integer"}}}},"example":{"relation":"Victim","notes":"Seen leaving scene","person":{"firstName":"John","lastName":"Smith","dob":"01/01/1990","phone":"555-111-2222","sex":"M","race":"W"}}},"RemovePersonRequest":{"type":"object","required":["personId"],"properties":{"personId":{"type":"integer"}},"example":{"personId":55}},"AddVehicleRequest":{"type":"object","properties":{"vehicleId":{"type":"integer","description":"Optional. Used when vehicle ID is already known, otherwise add vehicle object."},"notes":{"type":"string"},"vehicle":{"type":"object","properties":{"owner":{"type":"integer"},"license":{"type":"string"},"vin":{"type":"string"},"state":{"type":"string"},"type":{"type":"string"},"make":{"type":"string"},"model":{"type":"string"},"color":{"type":"string"},"year":{"type":"integer"},"profileImage":{"type":"string"}}}},"example":{"notes":"Parked on south curb","vehicle":{"license":"8ABC123","vin":"1HGCM82633A123456","state":"CA","type":"Sedan","make":"Honda","model":"Accord","color":"Black","year":2019}}},"RemoveVehicleRequest":{"type":"object","required":["vehicleId"],"properties":{"vehicleId":{"type":"integer"}},"example":{"vehicleId":88}},"MutationResponse":{"type":"object","properties":{"ok":{"type":"boolean"},"id":{"type":"integer"},"callID":{"type":"integer"},"tagId":{"type":"integer"},"personId":{"type":"integer"},"vehicleId":{"type":"integer"}}}}},"paths":{"/v1/health":{"get":{"tags":["Health"],"summary":"Health check","security":[],"responses":{"200":{"description":"Healthy","content":{"application/json":{"schema":{"$ref":"#/components/schemas/HealthResponse"}}}}}}},"/v1/incidents":{"get":{"tags":["Incidents"],"summary":"List open incidents, or filter by timestamp range","description":"With no query parameters, returns all open incidents for the authenticated tenant\n(`isClosed = 0`), ordered newest first.\n\nWhen `from` and `field` are provided, returns every incident (open or closed)\nwhose indexed unix-seconds timestamp falls within the inclusive range\n`[from, to]`. If `to` is omitted, it defaults to the current server time.\nThe `field` parameter selects which column to filter on:\n  - `timestamp` — incident creation time\n  - `timestamp_closed` — incident close time\n\nEach item is the full incident object — identical in shape to\n`GET /v1/incidents/{lookup}` — including `alternate_incidents`, `comments`,\n`units`, `tags`, `persons`, `vehicles`, `cases`, and `dispositions`.\n","parameters":[{"name":"from","in":"query","required":false,"description":"Inclusive lower bound, unix timestamp in seconds. Required together with `field`.","schema":{"type":"integer","format":"int64"},"example":1745280000},{"name":"to","in":"query","required":false,"description":"Inclusive upper bound, unix timestamp in seconds. Defaults to the current server time if omitted.","schema":{"type":"integer","format":"int64"},"example":1745366400},{"name":"field","in":"query","required":false,"description":"Which timestamp column to filter against. Required when `from` is provided.","schema":{"type":"string","enum":["timestamp","timestamp_closed"]}}],"responses":{"200":{"description":"Array of incidents","content":{"application/json":{"schema":{"type":"array","items":{"$ref":"#/components/schemas/Incident"}}}}},"400":{"description":"Invalid or incomplete range parameters","content":{"application/json":{"schema":{"$ref":"#/components/schemas/ErrorResponse"}}}},"401":{"description":"Missing or invalid API credentials","content":{"application/json":{"schema":{"$ref":"#/components/schemas/ErrorResponse"}}}},"500":{"description":"Server error","content":{"application/json":{"schema":{"$ref":"#/components/schemas/ErrorResponse"}}}}}},"post":{"tags":["Incidents"],"summary":"Create a new incident","requestBody":{"required":true,"content":{"application/json":{"schema":{"$ref":"#/components/schemas/CreateIncidentRequest"}}}},"responses":{"201":{"description":"Incident created","content":{"application/json":{"schema":{"$ref":"#/components/schemas/Incident"}}}},"400":{"description":"Validation or request error","content":{"application/json":{"schema":{"$ref":"#/components/schemas/ErrorResponse"}}}},"500":{"description":"Server error","content":{"application/json":{"schema":{"$ref":"#/components/schemas/ErrorResponse"}}}}}}},"/v1/incidents/{lookup}":{"get":{"tags":["Incidents"],"summary":"Get incident by global ID or incident number","parameters":[{"$ref":"#/components/parameters/LookupParam"}],"responses":{"200":{"description":"Incident","content":{"application/json":{"schema":{"$ref":"#/components/schemas/Incident"}}}},"404":{"description":"Incident not found","content":{"application/json":{"schema":{"$ref":"#/components/schemas/ErrorResponse"}}}}}}},"/v1/incidents/{lookup}/comments":{"post":{"tags":["Comments"],"summary":"Create an incident comment","parameters":[{"$ref":"#/components/parameters/LookupParam"}],"requestBody":{"required":true,"content":{"application/json":{"schema":{"$ref":"#/components/schemas/AddCommentRequest"}}}},"responses":{"201":{"description":"Comment created","content":{"application/json":{"schema":{"$ref":"#/components/schemas/Comment"}}}}}}},"/v1/incidents/{lookup}/comments/{commentId}":{"put":{"tags":["Comments"],"summary":"Update an incident comment","parameters":[{"$ref":"#/components/parameters/LookupParam"},{"$ref":"#/components/parameters/CommentIdParam"}],"requestBody":{"required":true,"content":{"application/json":{"schema":{"$ref":"#/components/schemas/UpdateCommentRequest"}}}},"responses":{"200":{"description":"Comment updated","content":{"application/json":{"schema":{"type":"object","properties":{"id":{"type":"integer"},"callid":{"type":"integer"},"comment":{"type":"string"},"updated":{"type":"boolean"}}}}}}}}},"/v1/incidents/{lookup}/tags":{"post":{"tags":["Tags"],"summary":"Add a tag to an incident","parameters":[{"$ref":"#/components/parameters/LookupParam"}],"requestBody":{"required":true,"content":{"application/json":{"schema":{"$ref":"#/components/schemas/AddTagRequest"}}}},"responses":{"200":{"description":"Tag added","content":{"application/json":{"schema":{"$ref":"#/components/schemas/MutationResponse"}}}}}},"delete":{"tags":["Tags"],"summary":"Remove a tag from an incident","parameters":[{"$ref":"#/components/parameters/LookupParam"}],"requestBody":{"required":true,"content":{"application/json":{"schema":{"$ref":"#/components/schemas/RemoveTagRequest"}}}},"responses":{"200":{"description":"Tag removed","content":{"application/json":{"schema":{"$ref":"#/components/schemas/MutationResponse"}}}}}}},"/v1/incidents/{lookup}/persons":{"post":{"tags":["Persons"],"summary":"Add or create-and-link a person on an incident","parameters":[{"$ref":"#/components/parameters/LookupParam"}],"requestBody":{"required":true,"content":{"application/json":{"schema":{"$ref":"#/components/schemas/AddPersonRequest"}}}},"responses":{"201":{"description":"Person linked","content":{"application/json":{"schema":{"$ref":"#/components/schemas/MutationResponse"}}}}}},"delete":{"tags":["Persons"],"summary":"Remove a person from an incident","parameters":[{"$ref":"#/components/parameters/LookupParam"}],"requestBody":{"required":true,"content":{"application/json":{"schema":{"$ref":"#/components/schemas/RemovePersonRequest"}}}},"responses":{"200":{"description":"Person removed","content":{"application/json":{"schema":{"$ref":"#/components/schemas/MutationResponse"}}}}}}},"/v1/incidents/{lookup}/vehicles":{"post":{"tags":["Vehicles"],"summary":"Add or create-and-link a vehicle on an incident","parameters":[{"$ref":"#/components/parameters/LookupParam"}],"requestBody":{"required":true,"content":{"application/json":{"schema":{"$ref":"#/components/schemas/AddVehicleRequest"}}}},"responses":{"201":{"description":"Vehicle linked","content":{"application/json":{"schema":{"$ref":"#/components/schemas/MutationResponse"}}}}}},"delete":{"tags":["Vehicles"],"summary":"Remove a vehicle from an incident","parameters":[{"$ref":"#/components/parameters/LookupParam"}],"requestBody":{"required":true,"content":{"application/json":{"schema":{"$ref":"#/components/schemas/RemoveVehicleRequest"}}}},"responses":{"200":{"description":"Vehicle removed","content":{"application/json":{"schema":{"$ref":"#/components/schemas/MutationResponse"}}}}}}}}}
